generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  college      String?
  createdAt    DateTime      @default(now())
  userSubjects UserSubject[]
  groups       GroupMember[]
  createdGroups StudyGroup[] @relation("GroupCreator")
  messages     Message[]
  ratingsGiven Rating[]      @relation("Rater")
  ratingsRecv  Rating[]      @relation("Rated")
}

model Subject {
  id          Int          @id @default(autoincrement())
  subjectName String       @unique
  userSubjects UserSubject[]
  groups      StudyGroup[]
}

model UserSubject {
  id               Int      @id @default(autoincrement())
  userId           Int
  subjectId        Int
  skillLevel       String
  availabilityTime String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject          Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model StudyGroup {
  id           Int           @id @default(autoincrement())
  groupName    String
  subjectId    Int
  scheduleTime String
  createdBy    Int
  subject      Subject       @relation(fields: [subjectId], references: [id])
  creator      User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members      GroupMember[]
  messages     Message[]
  ratings      Rating[]
}

model GroupMember {
  id      Int        @id @default(autoincrement())
  groupId Int
  userId  Int
  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Message {
  id        Int        @id @default(autoincrement())
  groupId   Int
  userId    Int
  message   String
  timestamp DateTime   @default(now())
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rating {
  id        Int        @id @default(autoincrement())
  groupId   Int
  raterId   Int
  ratedUser Int
  rating    Int
  feedback  String?
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  rater     User       @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  rated     User       @relation("Rated", fields: [ratedUser], references: [id], onDelete: Cascade)
}
